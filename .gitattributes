#
# https://help.github.com/articles/dealing-with-line-endings/
#

# Default text handling
*               text=auto

# Source files should use lf
*.java          text eol=lf
*.kt            text eol=lf
*.kts           text eol=lf
*.toml          text eol=lf
*.properties    text eol=lf
*.md            text eol=lf
*.txt           text eol=lf

# Linux start script should use lf
/gradlew        text eol=lf

# Windows script files should use crlf
*.bat           text eol=crlf
*.cmd           text eol=crlf
*.ps1           text eol=crlf

# Binary files should be left untouched
*.jar           binary
*.png           binary
*.ico           binary
*.zip           binary
